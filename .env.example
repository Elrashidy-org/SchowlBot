NODE_ENV=development
PORT=3001
PUBLIC_API_BASE_URL=http://localhost:3001
DEFAULT_TIMEZONE=Africa/Cairo
CORS_ALLOWED_ORIGINS=https://schowl.com,https://www.schowl.com,https://api.schowl.com,http://localhost:3000

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# Only needed for instant per-guild command deploys (npm run commands:deploy -- --guild).
# Production uses global commands across all Schowl servers and does not need this.
DISCORD_GUILD_ID=
# REQUIRED to bootstrap admin access: comma-separated Discord user IDs of the owner(s).
# Owners can run /config role grant to give other staff admin/sales/team_lead/teacher.
DISCORD_OWNER_IDS=
# Optional legacy fallback. Leads channels are now set per-server via /config channel set leads.
DISCORD_LEADS_CHANNEL_ID=
DISCORD_SALES_ROLE_ID=
DISCORD_TEACHER_ROLE_ID=

# REQUIRED in production: this is what actually protects the public lead endpoint.
# With NODE_ENV=production the API refuses leads if this is unset. Keep the site
# key on the frontend and this secret here; both must be from the same widget,
# whose allowed hostnames must include your real domain.
TURNSTILE_SECRET_KEY=

RESEND_API_KEY=
RESEND_FROM_EMAIL=Schowl <noreply@schowl.com>
ADMIN_NOTIFY_EMAIL=

# Lead handling
LEAD_SLA_HOURS=2
AUTO_ASSIGN_LEADS=true

# Optional: Google Calendar/Meet for auto-generated meeting links.
# Leave blank to disable; the bot works without it.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary
# Optional: logo image shown in emails (defaults to the schowl.com logo)
EMAIL_LOGO_URL=https://www.schowl.com/brand/SCHOWL.png
# Per-course email link pattern (set once your site has /courses/{slug} pages):
EMAIL_COURSE_URL_TEMPLATE=
